# =================================================================
# JobTracker Pro - Environment Configuration
# =================================================================

# --- API KEYS ---
# Gemini API Keys (Comma-separated for rotation)
# Get yours at https://aistudio.google.com/
GEMINI_KEYS=YOUR_API_KEY_1,YOUR_API_KEY_2

# Optional: Anthropic API Key for advanced AI ranking
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# --- SERVER CONFIG ---
# Flask Security (Random string for session encryption)
# Generate one with: python -c "import secrets; print(secrets.token_hex(24))"
FLASK_SECRET_KEY=yoursecretkeyhere

# Server Port (Default is 5000)
PORT=5000

# --- SCRAPER SETTINGS ---
# Maximum pages to paginate per site (Default: 5)
MAX_PAGES=5

# Maximum concurrent worker threads (Default: 6)
MAX_WORKERS=6
